					</svg>
					<span class="text-white font-bold text-sm">Discord</span>
					<span class="text-slate-500 text-xs mt-1 mono">moran_38b</span>
				</a>

				<a href="mailto:your-email@example.com" class="group p-6 bg-slate-800/30 border border-slate-700 rounded-2xl hover:border-amber-500 transition-all duration-300 flex flex-col items-center">
