					<span class="text-white font-bold text-sm">GitHub</span>
					<span class="text-slate-500 text-xs mt-1 mono">@Moran-38B</span>
				</a>
				
				<a href="https://discord.com/users/607190452806090762" target="_blank" class="group p-6 bg-slate-800/30 border border-slate-700 rounded-2xl hover:border-[#5865F2] transition-all duration-300 flex flex-col items-center">
					<svg class="w-8 h-8 text-slate-400 group-hover:text-[#5865F2] mb-3" fill="currentColor" viewBox="0 0 24 24">
